# ========================
#  GICPL .gitignore
# ========================

# ---------- Dependencies ----------
node_modules/
package-lock.json

# ---------- Environment Variables ----------
.env
.env.*
!.env.example

# ---------- Build Output ----------
frontend/dist/
frontend/.vite/

# ---------- Logs ----------
backend/logs/*.log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- OS Files ----------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ---------- Testing ----------
coverage/
.nyc_output/

# ---------- Misc ----------
*.tgz
*.pid
*.seed
*.pid.lock
